[
	{
		"id": "openapi_basic_spec_generation",
		"description": "Tests OpenAPI specification is generated from route definitions",
		"category": "openapi",
		"http": {
			"handler": {
				"route": "/openapi.json",
				"method": "GET"
			},
			"request": {
				"method": "GET",
				"path": "/openapi.json"
			},
			"expected_response": {
				"status_code": 200,
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"openapi": "3.0.0",
					"info": {
						"title": "API"
					}
				}
			}
		},
		"tags": ["openapi", "specification"]
	},
