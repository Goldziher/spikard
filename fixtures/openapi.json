	{
		"id": "openapi_contact_information",
		"description": "Tests OpenAPI spec includes contact information",
		"category": "openapi",
		"http": {
			"handler": {
				"route": "/openapi.json",
				"method": "GET"
			},
			"request": {
				"method": "GET",
				"path": "/openapi.json"
			},
			"expected_response": {
