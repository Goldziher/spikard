						{
							"url": "https://staging-api.example.com"
						}
					]
				}
			}
		},
		"tags": ["openapi", "servers"]
	},
	{
		"id": "openapi_security_schemes_definition",
		"description": "Tests OpenAPI spec includes security schemes",
		"category": "openapi",
		"http": {
			"handler": {
				"route": "/openapi.json",
				"method": "GET"
			},
			"request": {
				"method": "GET",
				"path": "/openapi.json"
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"components": {
						"securitySchemes": {
							"bearerAuth": {
								"type": "http",
								"scheme": "bearer"
							}
						}
					}
				}
			}
		},
		"tags": ["openapi", "security_schemes"]
	},
