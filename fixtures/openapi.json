	{
		"id": "openapi_servers_configuration",
		"description": "Tests OpenAPI spec includes configured servers",
		"category": "openapi",
		"http": {
			"handler": {
				"route": "/openapi.json",
				"method": "GET"
			},
			"request": {
				"method": "GET",
				"path": "/openapi.json"
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"servers": [
						{
							"url": "https://api.example.com"
