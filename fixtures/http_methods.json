	{
		"id": "put_validation_error",
		"description": "Tests PUT with invalid data returns 422",
		"category": "http_methods",
		"http": {
			"handler": {
				"route": "/items/{id}",
				"method": "PUT",
				"body_schema": {
					"$schema": "https://json-schema.org/draft/2020-12/schema",
					"type": "object",
					"required": ["id", "name", "price"],
					"properties": {
						"id": {
							"type": "integer"
						},
						"name": {
							"type": "string",
							"minLength": 3
						},
						"price": {
							"type": "number",
							"exclusiveMinimum": 0
						}
					}
				},
				"parameters": {
					"path": {
						"id": {
							"type": "string"
						}
					}
				}
			},
			"request": {
				"method": "PUT",
				"path": "/items/1",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"id": 1,
					"name": "X",
					"price": -10
				}
			},
			"expected_response": {
				"status_code": 422,
				"body": {
					"type": "https://spikard.dev/errors/validation-error",
					"title": "Request Validation Failed",
					"status": 422,
					"detail": "2 validation errors in request",
					"errors": [
						{
							"type": "string_too_short",
							"loc": ["body", "name"],
							"msg": "String should have at least 3 characters",
							"input": "X",
							"ctx": {
								"min_length": 3
							}
						},
						{
							"type": "greater_than",
							"loc": ["body", "price"],
							"msg": "Input should be greater than 0",
							"input": -10,
							"ctx": {
								"gt": 0
							}
						}
					]
				}
			}
		}
	},
	{
		"id": "put_missing_required_field",
		"description": "Tests PUT with missing required fields returns 422",
		"category": "http_methods",
		"http": {
			"handler": {
				"route": "/items/{id}",
				"method": "PUT",
				"body_schema": {
					"type": "object",
					"properties": {
						"id": {
							"type": "integer"
						},
						"name": {
							"type": "string"
						},
						"price": {
							"type": "string"
						}
					},
					"required": ["price"]
				},
				"parameters": {
					"path": {
						"id": {
							"type": "string"
						}
					}
				}
			},
			"request": {
				"method": "PUT",
				"path": "/items/1",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"id": 1,
					"name": "Item Name"
				}
			},
			"expected_response": {
				"status_code": 422,
				"body": {
					"type": "https://spikard.dev/errors/validation-error",
					"title": "Request Validation Failed",
					"status": 422,
					"detail": "1 validation error in request",
					"errors": [
						{
							"type": "missing",
							"loc": ["body", "price"],
							"msg": "Field required",
							"input": {
								"id": 1,
								"name": "Item Name"
							}
						}
					]
				}
			}
		}
	},
