	{
		"id": "rate_limit_ip_based_tracking",
		"description": "Tests rate limiting is applied per IP address",
		"category": "rate_limit",
		"http": {
			"handler": {
				"route": "/rate-limit/ip-based",
				"method": "GET",
				"middleware": {
					"rate_limit": {
						"per_second": 5,
						"burst": 5,
						"ip_based": true
					}
				}
			},
			"request": {
				"method": "GET",
				"path": "/rate-limit/ip-based",
				"headers": {
					"X-Forwarded-For": "192.168.1.100"
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"status": "ok"
				}
			}
		},
