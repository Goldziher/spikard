[
	{
		"id": "upload_file_basic_success",
		"description": "Tests basic file upload with single file",
		"category": "upload",
		"http": {
			"handler": {
				"route": "/upload",
				"method": "POST",
				"parameters": {
					"body": {
						"type": "multipart/form-data",
						"properties": {
							"file": {
								"type": "file"
							}
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/upload",
				"headers": {
					"Content-Type": "multipart/form-data"
				},
				"body": {
					"file": {
						"filename": "test.txt",
						"content": "Hello, World!"
					}
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"filename": "test.txt",
					"size": 13
				}
			}
		},
		"tags": ["upload", "file", "multipart"]
	},
	{
		"id": "upload_file_with_custom_content_type",
		"description": "Tests file upload preserves custom Content-Type",
		"category": "upload",
		"http": {
			"handler": {
				"route": "/upload/typed",
				"method": "POST",
				"parameters": {
					"body": {
						"type": "multipart/form-data",
						"properties": {
							"file": {
								"type": "file"
							}
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/upload/typed",
				"headers": {
					"Content-Type": "multipart/form-data"
				},
				"body": {
					"file": {
						"filename": "data.json",
						"content_type": "application/json",
						"content": "{\"key\": \"value\"}"
					}
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"filename": "data.json",
					"content_type": "application/json",
					"size": 16
				}
			}
		},
		"tags": ["upload", "content_type", "multipart"]
	},
	{
		"id": "upload_file_with_gzip_content_encoding",
		"description": "Tests file upload with gzip content encoding",
		"category": "upload",
		"http": {
			"handler": {
				"route": "/upload/compressed",
				"method": "POST",
				"parameters": {
					"body": {
						"type": "multipart/form-data",
						"properties": {
							"file": {
								"type": "file"
							}
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/upload/compressed",
				"headers": {
					"Content-Type": "multipart/form-data"
				},
				"body": {
					"file": {
						"filename": "data.gz",
						"content_encoding": "gzip",
						"content": "compressed data"
					}
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"filename": "data.gz",
					"content_encoding": "gzip"
				}
			}
		},
		"tags": ["upload", "content_encoding", "gzip"]
	},
	{
		"id": "upload_multiple_files",
		"description": "Tests uploading multiple files at once",
		"category": "upload",
		"http": {
			"handler": {
				"route": "/upload/multiple",
				"method": "POST",
				"parameters": {
					"body": {
						"type": "multipart/form-data",
						"properties": {
							"files": {
								"type": "file[]"
							}
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/upload/multiple",
				"headers": {
					"Content-Type": "multipart/form-data"
				},
				"body": {
					"files": [
						{
							"filename": "file1.txt",
							"content": "Content 1"
						},
						{
							"filename": "file2.txt",
							"content": "Content 2"
						}
					]
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"uploaded_files": 2,
					"total_size": 18
				}
			}
		},
		"tags": ["upload", "multiple_files", "multipart"]
	},
