	{
		"id": "upload_file_with_form_fields",
		"description": "Tests file upload with additional form fields",
		"category": "upload",
		"http": {
			"handler": {
				"route": "/upload/with-fields",
				"method": "POST",
				"parameters": {
					"body": {
						"type": "multipart/form-data",
						"properties": {
							"file": {
								"type": "file"
							},
							"description": {
								"type": "string"
							},
							"tags": {
								"type": "array"
							}
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/upload/with-fields",
				"headers": {
					"Content-Type": "multipart/form-data"
				},
				"body": {
					"file": {
						"filename": "document.pdf",
						"content": "PDF content"
					},
					"description": "Important document",
					"tags": ["important", "archive"]
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"filename": "document.pdf",
					"description": "Important document",
					"tags_count": 2
				}
			}
		},
		"tags": ["upload", "form_fields", "multipart"]
	},
	{
