							"file": {
								"type": "file"
							}
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/upload/auto-type",
				"headers": {
					"Content-Type": "multipart/form-data"
				},
				"body": {
					"file": {
						"filename": "unknown.xyz",
						"content": "Some content"
					}
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"filename": "unknown.xyz",
					"content_type": "application/octet-stream"
				}
			}
		},
		"tags": ["upload", "content_type", "default"]
	}
