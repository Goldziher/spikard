[
	{
		"id": "compression_gzip_applied",
		"description": "Serves a JSON payload compressed with gzip when the client advertises support.",
		"category": "compression",
		"http": {
			"handler": {
				"route": "/compression/gzip",
				"method": "GET",
				"middleware": {
					"compression": {
						"gzip": true,
						"brotli": false,
						"min_size": 0,
						"quality": 4
					}
				}
			},
			"request": {
				"method": "GET",
				"path": "/compression/gzip",
				"headers": {
					"Accept-Encoding": "gzip"
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"message": "Compressed payload",
					"payload": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
				},
				"headers": {
					"content-encoding": "gzip",
					"vary": "Accept-Encoding"
				}
			}
		},
		"tags": ["compression", "gzip", "middleware"]
	},
	{
		"id": "compression_payload_below_min_size_is_not_compressed",
		"description": "Ensures responses smaller than the configured min_size are sent uncompressed even when the client sends Accept-Encoding.",
		"category": "compression",
		"http": {
			"handler": {
				"route": "/compression/skip",
				"method": "GET",
				"middleware": {
					"compression": {
						"gzip": true,
						"brotli": false,
						"min_size": 4096,
						"quality": 6
					}
				}
			},
			"request": {
				"method": "GET",
				"path": "/compression/skip",
				"headers": {
					"Accept-Encoding": "gzip"
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"message": "Small payload",
					"payload": "tiny"
				},
				"headers": {
					"content-encoding": "<<absent>>"
				}
			}
		},
		"tags": ["compression", "gzip", "min_size"]
	}
]
