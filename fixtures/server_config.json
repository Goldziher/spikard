	{
		"id": "server_max_body_size_configuration",
		"description": "Tests server respects max body size limit",
		"category": "server_config",
		"http": {
			"handler": {
				"route": "/upload",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"data": {
							"type": "string"
						}
					},
					"required": ["data"]
				}
			},
			"request": {
				"method": "POST",
				"path": "/upload",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"data": "x"
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"received": 1
				}
			}
		},
		"tags": ["server_config", "max_body_size"]
	},
	{
		"id": "server_request_id_enabled",
