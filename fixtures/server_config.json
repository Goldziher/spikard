	{
		"id": "server_jwt_and_api_key_auth_combined",
		"description": "Tests server with both JWT and API key authentication configured",
		"category": "server_config",
		"http": {
			"handler": {
				"route": "/secure",
				"method": "GET",
				"parameters": {
					"headers": {
						"Authorization": {
							"type": "string"
						},
						"X-API-Key": {
							"type": "string"
						}
					}
				},
				"middleware": {
					"jwt_auth": {
						"enabled": true,
						"algorithm": "HS256",
						"secret": "test-secret"
					},
					"api_key_auth": {
						"enabled": true,
						"header": "X-API-Key"
					}
				}
			},
			"request": {
				"method": "GET",
				"path": "/secure",
				"headers": {
					"Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ0ZXN0IiwiZXhwIjoyNjI2NzgzOTQ2fQ.test"
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"authenticated": true
				}
			}
		},
		"tags": ["server_config", "auth", "jwt", "api_key"]
	},
	{
		"id": "server_rate_limit_configuration",
		"description": "Tests server enforces rate limiting configuration",
		"category": "server_config",
		"http": {
			"handler": {
				"route": "/limited",
				"method": "GET",
				"middleware": {
					"rate_limit": {
						"enabled": true,
						"requests_per_second": 10
					}
				}
			},
			"request": {
				"method": "GET",
				"path": "/limited"
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"limited": false
				}
			}
		},
		"tags": ["server_config", "rate_limit"]
	},
