[
  {
    "id": "cors_request_blocked",
    "description": "Tests CORS request from disallowed origin",
    "category": "cors",
    "http": {
      "handler": {
        "route": "/items/",
        "method": "GET",
        "parameters": {
          "headers": {
            "Origin": {
              "type": "string",
              "optional": true
            }
          }
        }
      },
      "request": {
        "method": "GET",
        "path": "/items/",
        "headers": {
          "Origin": "https://malicious-site.com"
        }
      },
      "expected_response": {
        "status_code": 403,
        "body": {
          "detail": "CORS request from origin 'https://malicious-site.com' not allowed"
        }
      }
    }
  },
  {
    "id": "06_cors_preflight_method_not_allowed",
    "description": "CORS preflight request for non-allowed method should be rejected",
    "category": "cors",
    "http": {
      "handler": {
        "route": "/api/data",
        "method": "GET",
        "parameters": {
          "headers": {
            "Origin": {
              "type": "string",
              "optional": true
            },
            "Access-Control-Request-Method": {
              "type": "string",
              "optional": true
            },
            "Access-Control-Request-Headers": {
              "type": "string",
              "optional": true
            }
          }
        }
      },
      "request": {
        "method": "OPTIONS",
        "path": "/api/data",
        "headers": {
          "Origin": "https://example.com",
          "Access-Control-Request-Method": "DELETE",
          "Access-Control-Request-Headers": "Content-Type"
        }
      },
      "expected_response": {
        "status_code": 403
      }
    },
    "tags": [
      "cors",
      "preflight",
      "method",
      "validation",
      "error"
    ]
  },
  {
    "id": "07_cors_preflight_header_not_allowed",
    "description": "CORS preflight request with non-allowed header should be rejected",
    "category": "cors",
    "http": {
      "handler": {
        "route": "/api/data",
        "method": "POST",
        "parameters": {
          "headers": {
            "Origin": {
              "type": "string",
              "optional": true
            },
            "Access-Control-Request-Method": {
              "type": "string",
              "optional": true
            },
            "Access-Control-Request-Headers": {
              "type": "string",
              "optional": true
            }
          }
        }
      },
      "request": {
        "method": "OPTIONS",
        "path": "/api/data",
        "headers": {
          "Origin": "https://example.com",
          "Access-Control-Request-Method": "POST",
          "Access-Control-Request-Headers": "X-Custom-Header"
        }
      },
      "expected_response": {
        "status_code": 403
      }
    },
    "tags": [
      "cors",
      "preflight",
      "headers",
      "validation",
      "error"
    ]
  },
  {
    "id": "08_cors_max_age",
    "description": "CORS preflight response should include Access-Control-Max-Age",
    "category": "cors",
    "http": {
      "handler": {
        "route": "/api/data",
        "method": "POST",
        "parameters": {
          "headers": {
            "Origin": {
              "type": "string",
              "optional": true
            },
            "Access-Control-Request-Method": {
              "type": "string",
              "optional": true
            },
            "Access-Control-Request-Headers": {
              "type": "string",
              "optional": true
            }
          }
        }
      },
      "request": {
        "method": "OPTIONS",
        "path": "/api/data",
        "headers": {
          "Origin": "https://example.com",
          "Access-Control-Request-Method": "POST",
          "Access-Control-Request-Headers": "Content-Type"
        }
      },
      "expected_response": {
        "status_code": 204,
        "headers": {
          "Access-Control-Allow-Origin": "https://example.com",
          "Access-Control-Allow-Methods": "POST",
          "Access-Control-Allow-Headers": "Content-Type",
          "Access-Control-Max-Age": "3600"
        }
      }
    },
    "tags": [
      "cors",
      "preflight",
      "max_age",
      "success"
    ]
  },
  {
    "id": "09_cors_expose_headers",
    "description": "CORS response should include Access-Control-Expose-Headers for custom headers",
    "category": "cors",
    "http": {
      "handler": {
        "route": "/api/data",
        "method": "GET",
        "parameters": {
          "headers": {
            "Origin": {
              "type": "string",
              "optional": true
            }
          }
        }
      },
      "request": {
        "method": "GET",
        "path": "/api/data",
        "headers": {
          "Origin": "https://example.com"
        }
      },
      "expected_response": {
        "status_code": 200,
        "headers": {
          "Access-Control-Allow-Origin": "https://example.com",
          "Access-Control-Expose-Headers": "X-Total-Count, X-Request-Id",
          "X-Total-Count": "42",
          "X-Request-Id": "abc123"
        }
      }
    },
    "tags": [
      "cors",
      "expose_headers",
      "success"
    ]
  },
  {
    "id": "10_cors_origin_null",
    "description": "CORS request with 'null' origin should be handled according to policy",
    "category": "cors",
    "http": {
      "handler": {
        "route": "/api/data",
        "method": "GET",
        "parameters": {
          "headers": {
            "Origin": {
              "type": "string",
              "optional": true
            }
          }
        }
      },
      "request": {
        "method": "GET",
        "path": "/api/data",
        "headers": {
          "Origin": "null"
        }
      },
      "expected_response": {
        "status_code": 403,
        "body": {
          "error": "Origin 'null' is not allowed"
        }
      }
    },
    "tags": [
      "cors",
      "null_origin",
      "security",
      "error"
    ]
  },
  {
    "id": "cors_safelisted_headers_without_preflight",
    "description": "Tests that safelisted headers (Content-Type: text/plain, Accept, Accept-Language) don't require preflight",
    "category": "cors",
    "http": {
      "handler": {
        "route": "/api/form",
        "method": "POST"
      },
      "request": {
        "method": "POST",
        "path": "/api/form",
        "headers": {
          "Origin": "https://app.example.com",
          "Content-Type": "text/plain",
          "Accept": "application/json",
          "Accept-Language": "en-US"
        }
      },
      "expected_response": {
        "status_code": 200,
        "body": {
          "message": "Success"
        },
        "headers": {
          "Access-Control-Allow-Origin": "https://app.example.com",
          "Vary": "Origin"
        }
      }
    }
  }
]
