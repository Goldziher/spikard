[
  {
    "id": "request_id_is_generated_when_not_provided",
    "description": "Ensures the request ID middleware attaches a UUID to responses when the client does not send one.",
    "category": "request_id",
    "http": {
      "handler": {
        "route": "/request-id/generated",
        "method": "GET",
        "middleware": {
          "request_id": {
            "enabled": true
          }
        }
      },
      "request": {
        "method": "GET",
        "path": "/request-id/generated"
      },
      "expected_response": {
        "status_code": 200,
        "body": {
          "status": "generated"
        },
        "headers": {
          "x-request-id": "<<uuid>>"
        }
      }
    },
    "tags": [
      "request_id",
      "middleware"
    ]
  },
  {
    "id": "request_id_header_is_preserved",
    "description": "When the client supplies X-Request-ID the same value should appear on the response.",
    "category": "request_id",
    "http": {
      "handler": {
        "route": "/request-id/preserved",
        "method": "GET"
      },
      "request": {
        "method": "GET",
        "path": "/request-id/preserved",
        "headers": {
          "X-Request-ID": "trace-123"
        }
      },
      "expected_response": {
        "status_code": 200,
        "body": {
          "status": "preserved",
          "echo": "trace-123"
        },
        "headers": {
          "x-request-id": "trace-123"
        }
      }
    },
    "tags": [
      "request_id",
      "propagation"
    ]
  },
  {
    "id": "request_id_middleware_can_be_disabled",
    "description": "When request ID generation is disabled the response should not contain X-Request-ID even if the client sends a header.",
    "category": "request_id",
    "http": {
      "handler": {
        "route": "/request-id/disabled",
        "method": "GET",
        "middleware": {
          "request_id": {
            "enabled": false
          }
        }
      },
      "request": {
        "method": "GET",
        "path": "/request-id/disabled",
        "headers": {
          "X-Request-ID": "external-id"
        }
      },
      "expected_response": {
        "status_code": 200,
        "body": {
          "status": "no-request-id"
        },
        "headers": {
          "x-request-id": "<<absent>>"
        }
      }
    },
    "tags": [
      "request_id",
      "disabled"
    ]
  }
]
