[
	{
		"id": "openrpc_method_handler_basic",
		"description": "Tests calling a method defined in an OpenRPC spec that takes typed params and returns a typed result",
		"category": "openrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": { "type": "string" },
						"method": { "type": "string" },
						"params": { "type": "object" },
						"id": { "type": ["integer", "string"] }
					},
					"required": ["jsonrpc", "method", "id"]
				},
				"middleware": {
					"openrpc": {
						"enabled": true,
						"spec": {
							"openrpc": "1.3.2",
							"info": { "title": "Math API", "version": "1.0.0" },
							"methods": [
								{
									"name": "add",
									"params": [
										{ "name": "a", "required": true, "schema": { "type": "integer" } },
										{ "name": "b", "required": true, "schema": { "type": "integer" } }
									],
									"result": {
										"name": "sum",
										"schema": { "type": "integer" }
									}
								}
							]
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": { "Content-Type": "application/json" },
				"body": {
					"jsonrpc": "2.0",
					"method": "add",
					"params": { "a": 10, "b": 5 },
					"id": 1
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"jsonrpc": "2.0",
					"result": 15,
					"id": 1
				}
			}
		},
		"tags": ["openrpc", "method", "params", "result"]
	},
	{
		"id": "openrpc_param_validation_wrong_type",
		"description": "Tests that a parameter with wrong type is rejected per the OpenRPC method param schema",
		"category": "openrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": { "type": "string" },
						"method": { "type": "string" },
						"params": {},
						"id": { "type": ["integer", "string"] }
					},
					"required": ["jsonrpc", "method", "id"]
				},
				"middleware": {
					"openrpc": {
						"enabled": true,
						"spec": {
							"openrpc": "1.3.2",
							"info": { "title": "Math API", "version": "1.0.0" },
							"methods": [
								{
									"name": "multiply",
									"params": [{ "name": "factor", "required": true, "schema": { "type": "integer" } }],
									"result": { "name": "product", "schema": { "type": "integer" } }
								}
							]
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": { "Content-Type": "application/json" },
				"body": {
					"jsonrpc": "2.0",
					"method": "multiply",
					"params": { "factor": "not_a_number" },
					"id": 2
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"jsonrpc": "2.0",
					"error": {
						"code": -32602,
						"message": "Invalid params"
					},
					"id": 2
				}
			}
		},
		"tags": ["openrpc", "validation", "param_type", "error"]
	},
	{
		"id": "openrpc_param_validation_missing_required",
		"description": "Tests that a missing required parameter is rejected per the OpenRPC method param schema",
		"category": "openrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": { "type": "string" },
						"method": { "type": "string" },
						"params": {},
						"id": { "type": ["integer", "string"] }
					},
					"required": ["jsonrpc", "method", "id"]
				},
				"middleware": {
					"openrpc": {
						"enabled": true,
						"spec": {
							"openrpc": "1.3.2",
							"info": { "title": "User API", "version": "1.0.0" },
							"methods": [
								{
									"name": "user.create",
									"params": [
										{ "name": "name", "required": true, "schema": { "type": "string" } },
										{ "name": "email", "required": true, "schema": { "type": "string", "format": "email" } }
									],
									"result": {
										"name": "user",
										"schema": {
											"type": "object",
											"properties": {
												"id": { "type": "integer" },
												"name": { "type": "string" },
												"email": { "type": "string" }
											}
										}
									}
								}
							]
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": { "Content-Type": "application/json" },
				"body": {
					"jsonrpc": "2.0",
					"method": "user.create",
					"params": { "name": "Alice" },
					"id": 3
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"jsonrpc": "2.0",
					"error": {
						"code": -32602,
						"message": "Invalid params"
					},
					"id": 3
				}
			}
		},
		"tags": ["openrpc", "validation", "required_param", "error"]
	},
	{
		"id": "openrpc_multi_method_spec",
		"description": "Tests that a spec with multiple methods routes correctly to each registered handler",
		"category": "openrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": { "type": "string" },
						"method": { "type": "string" },
						"params": { "type": "object" },
						"id": { "type": ["integer", "string"] }
					},
					"required": ["jsonrpc", "method", "id"]
				},
				"middleware": {
					"openrpc": {
						"enabled": true,
						"spec": {
							"openrpc": "1.3.2",
							"info": { "title": "Multi Method API", "version": "1.0.0" },
							"methods": [
								{
									"name": "ping",
									"params": [],
									"result": { "name": "pong", "schema": { "type": "string" } }
								},
								{
									"name": "echo",
									"params": [{ "name": "message", "required": true, "schema": { "type": "string" } }],
									"result": { "name": "echo", "schema": { "type": "string" } }
								}
							]
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": { "Content-Type": "application/json" },
				"body": {
					"jsonrpc": "2.0",
					"method": "echo",
					"params": { "message": "hello world" },
					"id": 10
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"jsonrpc": "2.0",
					"result": "hello world",
					"id": 10
				}
			}
		},
		"tags": ["openrpc", "multi_method", "routing"]
	},
	{
		"id": "openrpc_batch_request_all_valid",
		"description": "Tests batch request against OpenRPC-defined methods where all calls are valid",
		"category": "openrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "array"
				},
				"middleware": {
					"openrpc": {
						"enabled": true,
						"spec": {
							"openrpc": "1.3.2",
							"info": { "title": "Calc API", "version": "1.0.0" },
							"methods": [
								{
									"name": "add",
									"params": [
										{ "name": "a", "required": true, "schema": { "type": "integer" } },
										{ "name": "b", "required": true, "schema": { "type": "integer" } }
									],
									"result": { "name": "sum", "schema": { "type": "integer" } }
								}
							]
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": { "Content-Type": "application/json" },
				"body": [
					{ "jsonrpc": "2.0", "method": "add", "params": { "a": 1, "b": 2 }, "id": 1 },
					{ "jsonrpc": "2.0", "method": "add", "params": { "a": 10, "b": 20 }, "id": 2 }
				]
			},
			"expected_response": {
				"status_code": 200,
				"body": [{ "jsonrpc": "2.0", "result": 3, "id": 1 }, { "jsonrpc": "2.0", "result": 30, "id": 2 }]
			}
		},
		"tags": ["openrpc", "batch", "all_valid"]
	},
	{
		"id": "openrpc_batch_mixed_valid_invalid",
		"description": "Tests batch request where some calls are valid and some reference undefined methods",
		"category": "openrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "array"
				},
				"middleware": {
					"openrpc": {
						"enabled": true,
						"spec": {
							"openrpc": "1.3.2",
							"info": { "title": "Calc API", "version": "1.0.0" },
							"methods": [
								{
									"name": "add",
									"params": [
										{ "name": "a", "required": true, "schema": { "type": "integer" } },
										{ "name": "b", "required": true, "schema": { "type": "integer" } }
									],
									"result": { "name": "sum", "schema": { "type": "integer" } }
								}
							]
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": { "Content-Type": "application/json" },
				"body": [
					{ "jsonrpc": "2.0", "method": "add", "params": { "a": 5, "b": 5 }, "id": 1 },
					{ "jsonrpc": "2.0", "method": "nonexistent", "params": {}, "id": 2 }
				]
			},
			"expected_response": {
				"status_code": 200,
				"body": [
					{ "jsonrpc": "2.0", "result": 10, "id": 1 },
					{ "jsonrpc": "2.0", "error": { "code": -32601, "message": "Method not found" }, "id": 2 }
				]
			}
		},
		"tags": ["openrpc", "batch", "mixed", "error"]
	},
	{
		"id": "openrpc_method_namespacing",
		"description": "Tests method with dot-namespaced name such as account.create is dispatched correctly",
		"category": "openrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": { "type": "string" },
						"method": { "type": "string" },
						"params": { "type": "object" },
						"id": { "type": ["integer", "string"] }
					},
					"required": ["jsonrpc", "method", "id"]
				},
				"middleware": {
					"openrpc": {
						"enabled": true,
						"spec": {
							"openrpc": "1.3.2",
							"info": { "title": "Account API", "version": "1.0.0" },
							"methods": [
								{
									"name": "account.create",
									"params": [
										{ "name": "username", "required": true, "schema": { "type": "string" } },
										{ "name": "email", "required": true, "schema": { "type": "string" } }
									],
									"result": {
										"name": "account",
										"schema": {
											"type": "object",
											"properties": {
												"id": { "type": "integer" },
												"username": { "type": "string" }
											}
										}
									}
								}
							]
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": { "Content-Type": "application/json" },
				"body": {
					"jsonrpc": "2.0",
					"method": "account.create",
					"params": { "username": "alice", "email": "alice@example.com" },
					"id": 1
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"jsonrpc": "2.0",
					"result": {
						"id": 1,
						"username": "alice"
					},
					"id": 1
				}
			}
		},
		"tags": ["openrpc", "namespace", "dotted_method"]
	},
	{
		"id": "openrpc_optional_param_omitted",
		"description": "Tests that a method call omitting an optional parameter succeeds using its default behaviour",
		"category": "openrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": { "type": "string" },
						"method": { "type": "string" },
						"params": { "type": "object" },
						"id": { "type": ["integer", "string"] }
					},
					"required": ["jsonrpc", "method", "id"]
				},
				"middleware": {
					"openrpc": {
						"enabled": true,
						"spec": {
							"openrpc": "1.3.2",
							"info": { "title": "Search API", "version": "1.0.0" },
							"methods": [
								{
									"name": "search",
									"params": [
										{ "name": "query", "required": true, "schema": { "type": "string" } },
										{ "name": "limit", "required": false, "schema": { "type": "integer", "default": 10 } }
									],
									"result": {
										"name": "results",
										"schema": {
											"type": "object",
											"properties": {
												"items": { "type": "array" },
												"total": { "type": "integer" }
											}
										}
									}
								}
							]
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": { "Content-Type": "application/json" },
				"body": {
					"jsonrpc": "2.0",
					"method": "search",
					"params": { "query": "spikard" },
					"id": 5
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"jsonrpc": "2.0",
					"result": {
						"items": [],
						"total": 0
					},
					"id": 5
				}
			}
		},
		"tags": ["openrpc", "optional_param", "default"]
	},
	{
		"id": "openrpc_error_mapping_per_spec",
		"description": "Tests that application errors are mapped to the error codes defined in the OpenRPC spec errors array",
		"category": "openrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": { "type": "string" },
						"method": { "type": "string" },
						"params": { "type": "object" },
						"id": { "type": ["integer", "string"] }
					},
					"required": ["jsonrpc", "method", "id"]
				},
				"middleware": {
					"openrpc": {
						"enabled": true,
						"spec": {
							"openrpc": "1.3.2",
							"info": { "title": "Resource API", "version": "1.0.0" },
							"methods": [
								{
									"name": "resource.get",
									"params": [{ "name": "id", "required": true, "schema": { "type": "integer" } }],
									"result": {
										"name": "resource",
										"schema": { "type": "object" }
									},
									"errors": [{ "code": -32000, "message": "Resource not found" }]
								}
							]
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": { "Content-Type": "application/json" },
				"body": {
					"jsonrpc": "2.0",
					"method": "resource.get",
					"params": { "id": 99999 },
					"id": 7
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"jsonrpc": "2.0",
					"error": {
						"code": -32000,
						"message": "Resource not found"
					},
					"id": 7
				}
			}
		},
		"tags": ["openrpc", "error_mapping", "app_error"]
	},
	{
		"id": "openrpc_param_schema_ref_resolution",
		"description": "Tests that parameter schemas referenced via $ref in OpenRPC components/schemas are resolved",
		"category": "openrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": { "type": "string" },
						"method": { "type": "string" },
						"params": { "type": "object" },
						"id": { "type": ["integer", "string"] }
					},
					"required": ["jsonrpc", "method", "id"]
				},
				"middleware": {
					"openrpc": {
						"enabled": true,
						"spec": {
							"openrpc": "1.3.2",
							"info": { "title": "Address API", "version": "1.0.0" },
							"methods": [
								{
									"name": "address.validate",
									"params": [
										{
											"name": "address",
											"required": true,
											"schema": { "$ref": "#/components/schemas/Address" }
										}
									],
									"result": {
										"name": "valid",
										"schema": { "type": "boolean" }
									}
								}
							],
							"components": {
								"schemas": {
									"Address": {
										"type": "object",
										"properties": {
											"street": { "type": "string" },
											"city": { "type": "string" },
											"country": { "type": "string" }
										},
										"required": ["street", "city", "country"]
									}
								}
							}
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": { "Content-Type": "application/json" },
				"body": {
					"jsonrpc": "2.0",
					"method": "address.validate",
					"params": {
						"address": {
							"street": "123 Main St",
							"city": "Springfield",
							"country": "US"
						}
					},
					"id": 8
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"jsonrpc": "2.0",
					"result": true,
					"id": 8
				}
			}
		},
		"tags": ["openrpc", "schema_ref", "components", "resolution"]
	}
]
