  {
    "id": "optional_cookie_parameter_success",
    "description": "Tests optional cookie parameter with value provided",
    "category": "cookies",
    "http": {
      "handler": {
        "route": "/items/",
        "method": "GET",
        "parameters": {
          "cookies": {
            "ads_id": {
              "type": "string",
              "optional": true
            }
          }
        }
      },
      "request": {
        "method": "GET",
        "path": "/items/",
        "cookies": {
          "ads_id": "abc123"
        }
      },
      "expected_response": {
        "status_code": 200,
        "body": {
          "ads_id": "abc123"
        }
      }
    }
  },
