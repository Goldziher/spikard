[
	{
		"id": "jwt_authentication_valid_token",
		"description": "Tests JWT authentication with a valid token containing correct signature and claims",
		"category": "auth",
		"http": {
			"handler": {
				"route": "/protected/user",
				"method": "GET",
				"parameters": {
					"headers": {
						"Authorization": {
							"type": "string",
							"required": true,
							"description": "JWT token in Bearer format"
						}
					}
				},
				"middleware": {
					"jwt_auth": {
						"enabled": true,
						"algorithm": "HS256",
						"secret": "test-secret-key-do-not-use-in-production",
						"audience": ["https://api.example.com"],
						"issuer": "https://auth.example.com"
					}
				}
			},
			"request": {
				"method": "GET",
				"path": "/protected/user",
				"headers": {
					"Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ1c2VyMTIzIiwiZXhwIjoyNjI2NzgzOTQ2LCJpYXQiOjE3NjI3ODM5NDYsImF1ZCI6WyJodHRwczovL2FwaS5leGFtcGxlLmNvbSJdLCJpc3MiOiJodHRwczovL2F1dGguZXhhbXBsZS5jb20ifQ.TpRpCJeXROQ12-ehRCVZm6EgN7Dn6QpfoekxJvnzgQg"
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"message": "Access granted",
					"user_id": "user123"
				}
			}
		},
		"tags": ["auth", "jwt", "bearer", "security", "middleware", "success"]
	},
	{
