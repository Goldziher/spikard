  {
    "id": "422_unprocessable_entity_validation_error",
    "description": "Tests 422 for validation errors (Pydantic)",
    "category": "status_codes",
    "http": {
      "handler": {
        "route": "/items/",
        "method": "POST",
        "body_schema": {
          "type": "object",
          "properties": {
            "price": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "price",
            "name"
          ]
        }
      },
      "request": {
        "method": "POST",
        "path": "/items/",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "price": "not a number"
        }
      },
      "expected_response": {
        "status_code": 422,
        "body": {
          "type": "https://spikard.dev/errors/validation-error",
          "title": "Request Validation Failed",
          "status": 422,
          "detail": "1 validation error in request",
          "errors": [
            {
              "type": "missing",
              "loc": [
                "body",
                "name"
              ],
              "msg": "Field required",
              "input": {
                "price": "not a number"
              }
            }
          ]
        }
      }
    }
  },
  {
    "id": "408_request_timeout",
    "description": "Tests 408 status code when request takes too long",
    "category": "status_codes",
    "http": {
      "handler": {
        "route": "/slow-endpoint",
        "method": "POST",
        "body_schema": {
          "type": "object",
          "properties": {
            "data": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "data"
          ]
        }
      },
      "request": {
        "method": "POST",
        "path": "/slow-endpoint",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "data": "large_data"
        }
      },
      "expected_response": {
        "status_code": 408,
        "body": {
          "detail": "Request timeout"
        },
        "headers": {
          "Connection": "close"
        }
      }
    }
  },
  {
    "id": "19_413_payload_too_large",
    "description": "Request with body exceeding max size should return 413",
    "category": "status_codes",
    "http": {
      "handler": {
        "route": "/upload",
        "method": "POST",
        "body_schema": {
          "type": "object",
          "properties": {
            "data": {
              "type": "string"
            }
          }
        }
      },
      "request": {
        "method": "POST",
        "path": "/upload",
        "body": {
          "data": "{{ repeat 'x' 2000 times }}"
        }
      },
      "expected_response": {
        "status_code": 413,
        "body": {
          "error": "Payload Too Large",
          "message": "Request body size exceeds maximum allowed size of 1024 bytes"
        }
      }
    },
    "tags": [
      "status_codes",
      "413",
      "payload_size",
      "error"
    ]
  },
  {
