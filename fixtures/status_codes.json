[
  {
    "id": "200_ok_success",
    "description": "Tests standard 200 OK response for successful GET request",
    "category": "status_codes",
    "http": {
      "handler": {
        "route": "/status-test/{code}",
        "method": "GET",
        "parameters": {
          "path": {
            "code": {
              "type": "string"
            }
          }
        }
      },
      "request": {
        "method": "GET",
        "path": "/status-test/200"
      },
      "expected_response": {
        "status_code": 200,
        "body": {
          "id": 1,
          "name": "Item 1"
        }
      }
    }
  },
  {
