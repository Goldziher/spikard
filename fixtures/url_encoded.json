  {
    "id": "simple_form_submission_success",
    "description": "Tests basic URL-encoded form with username and password",
    "category": "url_encoded",
    "http": {
      "handler": {
        "route": "/login/",
        "method": "POST",
        "body_schema": {
          "type": "object",
          "required": [
            "username",
            "password"
          ],
          "properties": {
            "username": {
              "type": "string"
            },
            "password": {
              "type": "string"
            }
          }
        }
      },
      "request": {
        "method": "POST",
        "path": "/login/",
        "headers": {
          "Content-Type": "application/x-www-form-urlencoded"
        }
      },
      "expected_response": {
        "status_code": 200,
        "body": {
          "username": "johndoe"
        }
      }
    }
  },
