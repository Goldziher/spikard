[
  {
    "id": "user_agent_header_default_value",
    "description": "Tests optional User-Agent header when not provided, uses testclient default",
    "category": "headers",
    "http": {
      "handler": {
        "route": "/items/",
        "method": "GET",
        "parameters": {
          "headers": {
            "User-Agent": {
              "type": "string",
              "annotation": "str",
              "optional": true,
              "default": "testclient"
            }
          }
        }
      },
      "request": {
        "method": "GET",
        "path": "/items/"
      },
      "expected_response": {
        "status_code": 200,
        "body": {
          "User-Agent": "testclient"
        }
      }
    }
  },
