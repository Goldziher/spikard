  {
    "id": "header_case_insensitivity_access",
    "description": "Tests case-insensitive header access (Content-Type vs content-type)",
    "category": "headers",
    "http": {
      "handler": {
        "route": "/echo",
        "method": "POST",
        "body_schema": {
          "type": "object",
          "properties": {
            "test": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "test"
          ]
        }
      },
      "request": {
        "method": "POST",
        "path": "/echo",
        "headers": {
          "content-type": "application/json"
        },
        "body": {
          "test": "data"
        }
      },
      "expected_response": {
        "status_code": 200,
        "body": {
          "content_type_lower": "application/json",
          "content_type_upper": "application/json",
          "content_type_mixed": "application/json"
        }
      }
    }
  },
