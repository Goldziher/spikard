	{
		"id": "response_cache_control_header",
		"description": "Tests response includes Cache-Control header",
		"category": "response",
		"http": {
			"handler": {
				"route": "/static-resource",
				"method": "GET"
			},
			"request": {
				"method": "GET",
				"path": "/static-resource"
			},
			"expected_response": {
				"status_code": 200,
				"headers": {
