					"title": "Request Validation Failed",
					"status": 422,
					"detail": "1 validation error in request",
					"errors": [
						{
							"type": "enum",
							"loc": ["path", "model_name"],
							"msg": "Input should be 'alexnet', 'resnet' or 'lenet'",
							"input": "invalid_model",
							"ctx": {
								"expected": "'alexnet', 'resnet' or 'lenet'"
							}
						}
					]
				}
