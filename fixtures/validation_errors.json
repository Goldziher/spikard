[
	{
		"id": "query_param_type_error_string_provided_for_int",
		"description": "Tests validation error when string is provided for integer query param",
		"category": "validation_errors",
		"http": {
			"handler": {
				"route": "/items/",
				"method": "GET",
				"parameters": {
					"query": {
						"q": {
							"type": "string"
						},
						"skip": {
							"type": "integer"
						}
					}
				}
			},
			"request": {
				"method": "GET",
				"path": "/items/?q=test&skip=not_a_number",
				"headers": {
					"x-token": "test-token"
				}
			},
			"expected_response": {
				"status_code": 422,
				"body": {
					"type": "https://spikard.dev/errors/validation-error",
					"title": "Request Validation Failed",
					"status": 422,
					"detail": "1 validation error in request",
					"errors": [
						{
							"type": "int_parsing",
							"loc": ["query", "skip"],
							"msg": "Input should be a valid integer, unable to parse string as an integer",
							"input": "not_a_number"
						}
					]
				}
			}
		}
	},
