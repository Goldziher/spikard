	{
		"id": "jsonrpc_deprecated_method_flag",
		"description": "Tests JSON-RPC method marked as deprecated",
		"category": "jsonrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": {
							"type": "string"
						},
						"method": {
							"type": "string"
						},
						"id": {
							"type": ["integer", "string"]
						}
					},
					"required": ["jsonrpc", "method", "id"]
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"jsonrpc": "2.0",
					"method": "oldMethod",
					"params": {},
					"id": 1
				}
			},
			"expected_response": {
				"status_code": 200,
				"headers": {
					"Deprecation": "true",
					"Sunset": "<<present>>"
				},
				"body": {
					"jsonrpc": "2.0",
					"result": "deprecated",
					"id": 1
				}
			}
		},
		"tags": ["jsonrpc", "deprecated", "method"]
	},
