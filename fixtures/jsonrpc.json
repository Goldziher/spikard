	{
		"id": "jsonrpc_method_with_params_schema",
		"description": "Tests JSON-RPC method params validated against schema",
		"category": "jsonrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": {
							"type": "string"
						},
						"method": {
							"type": "string"
						},
						"params": {
							"type": "object",
							"properties": {
								"name": {
									"type": "string"
								},
								"age": {
									"type": "integer",
									"minimum": 0
								}
							},
							"required": ["name", "age"]
						},
						"id": {
							"type": ["integer", "string"]
						}
					},
					"required": ["jsonrpc", "method", "params", "id"]
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"jsonrpc": "2.0",
					"method": "createUser",
					"params": {
						"name": "Alice",
						"age": 30
					},
					"id": 1
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"jsonrpc": "2.0",
					"result": {
						"id": 1,
						"name": "Alice",
						"age": 30
					},
					"id": 1
				}
			}
		},
		"tags": ["jsonrpc", "params_schema", "validation"]
	},
