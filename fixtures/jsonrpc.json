	{
		"id": "jsonrpc_method_parameter_validation",
		"description": "Tests JSON-RPC validates parameter types and values",
		"category": "jsonrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": {
							"type": "string"
						},
						"method": {
							"type": "string",
							"minLength": 1
						},
						"params": {
							"type": "object"
						},
						"id": {
							"type": ["integer", "string"]
						}
					},
					"required": ["jsonrpc", "method", "params", "id"]
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"jsonrpc": "2.0",
					"method": "update_user",
					"params": {
						"id": 123,
						"name": "John Doe",
						"email": "john@example.com"
					},
					"id": 6
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"jsonrpc": "2.0",
					"result": {
						"id": 123,
						"name": "John Doe",
						"email": "john@example.com",
						"updated": true
					},
					"id": 6
				}
			}
		},
		"tags": ["jsonrpc", "validation", "params"]
	}
]
