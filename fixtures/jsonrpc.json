[
	{
		"id": "jsonrpc_single_call_success",
		"description": "Tests single JSON-RPC 2.0 call with successful response",
		"category": "jsonrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": {
							"type": "string"
						},
						"method": {
							"type": "string"
						},
						"params": {
							"type": "object"
						},
						"id": {
							"type": ["integer", "string"]
						}
					},
					"required": ["jsonrpc", "method", "id"]
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"jsonrpc": "2.0",
					"method": "add",
					"params": {
						"a": 5,
						"b": 3
					},
					"id": 1
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"jsonrpc": "2.0",
					"result": 8,
					"id": 1
				}
			}
		},
		"tags": ["jsonrpc", "success"]
	},
	{
		"id": "jsonrpc_call_with_positional_params",
		"description": "Tests JSON-RPC call with positional array parameters",
		"category": "jsonrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": {
							"type": "string"
						},
						"method": {
							"type": "string"
						},
						"params": {
							"type": "array"
						},
						"id": {
							"type": ["integer", "string"]
						}
					},
					"required": ["jsonrpc", "method", "id"]
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"jsonrpc": "2.0",
					"method": "multiply",
					"params": [4, 7],
					"id": 2
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"jsonrpc": "2.0",
					"result": 28,
					"id": 2
				}
			}
		},
		"tags": ["jsonrpc", "params", "positional"]
	},
	{
		"id": "jsonrpc_error_response",
		"description": "Tests JSON-RPC error response with error object",
		"category": "jsonrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"jsonrpc": {
							"type": "string"
						},
						"method": {
							"type": "string"
						},
						"params": {
							"type": "object"
						},
						"id": {
							"type": ["integer", "string"]
						}
					},
					"required": ["jsonrpc", "method", "id"]
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"jsonrpc": "2.0",
					"method": "divide",
					"params": {
						"numerator": 10,
						"denominator": 0
					},
					"id": 3
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"jsonrpc": "2.0",
					"error": {
						"code": -32600,
						"message": "Invalid Request",
						"data": "Division by zero"
					},
					"id": 3
				}
			}
		},
		"tags": ["jsonrpc", "error"]
	},
	{
		"id": "jsonrpc_batch_request",
		"description": "Tests JSON-RPC batch request with multiple calls",
		"category": "jsonrpc",
		"http": {
			"handler": {
				"route": "/rpc",
				"method": "POST",
				"body_schema": {
					"type": "array"
				}
			},
			"request": {
				"method": "POST",
				"path": "/rpc",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": [
					{
						"jsonrpc": "2.0",
						"method": "add",
						"params": [1, 2],
						"id": 1
					},
					{
						"jsonrpc": "2.0",
						"method": "subtract",
						"params": [5, 3],
						"id": 2
					}
				]
			},
			"expected_response": {
				"status_code": 200,
				"body": [
					{
						"jsonrpc": "2.0",
						"result": 3,
						"id": 1
					},
					{
						"jsonrpc": "2.0",
						"result": 2,
						"id": 2
					}
				]
			}
		},
		"tags": ["jsonrpc", "batch"]
	},
