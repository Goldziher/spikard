[
	{
		"id": "graphql_query_only_schema",
		"description": "Tests GraphQL schema configured with queries only",
		"category": "graphql_schema",
		"http": {
			"handler": {
				"route": "/graphql",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"query": {
							"type": "string"
						}
					},
					"required": ["query"]
				},
				"middleware": {
					"graphql": {
						"enabled": true,
						"schema_type": "query_only"
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/graphql",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"query": "{ user { id name } }"
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"data": {
						"user": {
							"id": "1",
							"name": "Test User"
						}
					}
				}
			}
		},
		"tags": ["graphql_schema", "query"]
	},
	{
		"id": "graphql_query_and_mutation_schema",
		"description": "Tests GraphQL schema with queries and mutations",
		"category": "graphql_schema",
		"http": {
			"handler": {
				"route": "/graphql",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"query": {
							"type": "string"
						}
					},
					"required": ["query"]
				},
				"middleware": {
					"graphql": {
						"enabled": true,
						"schema_type": "query_mutation"
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/graphql",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"query": "mutation { createUser(name: \"New\") { id name } }"
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"data": {
						"createUser": {
							"id": "2",
							"name": "New"
						}
					}
				}
			}
		},
		"tags": ["graphql_schema", "mutation"]
	},
	{
		"id": "graphql_full_schema_with_subscriptions",
		"description": "Tests GraphQL schema with queries, mutations, and subscriptions",
		"category": "graphql_schema",
		"http": {
			"handler": {
				"route": "/graphql",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"query": {
							"type": "string"
						}
					},
					"required": ["query"]
				},
				"middleware": {
					"graphql": {
						"enabled": true,
						"schema_type": "full"
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/graphql",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"query": "{ __typename }"
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"data": {
						"__typename": "Query"
					}
				}
			}
		},
		"tags": ["graphql_schema", "full", "subscriptions"]
	},
	{
		"id": "graphql_introspection_enabled",
		"description": "Tests GraphQL introspection is available",
		"category": "graphql_schema",
		"http": {
			"handler": {
				"route": "/graphql",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"query": {
							"type": "string"
						}
					},
					"required": ["query"]
				},
				"middleware": {
					"graphql": {
						"enabled": true,
						"introspection": true
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/graphql",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"query": "{ __schema { types { name } } }"
				}
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"data": {
						"__schema": {
							"types": null
						}
					}
				}
			}
		},
		"tags": ["graphql_schema", "introspection"]
	},
	{
