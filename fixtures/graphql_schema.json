	{
		"id": "graphql_authentication_error_variant",
		"description": "Tests GraphQL authentication error when auth fails",
		"category": "graphql_schema",
		"http": {
			"handler": {
				"route": "/graphql",
				"method": "POST",
				"parameters": {
					"headers": {
						"Authorization": {
							"type": "string",
							"required": true
						}
					}
				},
				"body_schema": {
					"type": "object",
					"properties": {
						"query": {
							"type": "string"
						}
					},
					"required": ["query"]
				},
				"middleware": {
					"graphql": {
						"enabled": true,
						"schema_type": "query_only"
					},
					"jwt_auth": {
						"enabled": true,
						"algorithm": "HS256",
						"secret": "test-secret"
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/graphql",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"query": "{ user { id } }"
				}
			},
			"expected_response": {
				"status_code": 401,
				"body": {
					"error": "<<present>>"
				}
			}
		},
		"tags": ["graphql_schema", "error", "authentication"]
	},
