						"query": {
							"type": "string"
						}
					},
					"required": ["query"]
				},
				"middleware": {
					"graphql": {
						"enabled": true,
						"introspection": false
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/graphql",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"query": "{ __schema { types { name } } }"
				}
			},
