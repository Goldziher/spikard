  {
    "id": "multiple_file_uploads",
    "description": "Upload multiple files in a single multipart request",
    "category": "multipart",
    "http": {
      "handler": {
        "route": "/",
        "method": "POST",
        "body_schema": {
          "type": "object",
          "properties": {
            "test1": {
              "type": "string",
              "format": "binary"
            },
            "test2": {
              "type": "string",
              "format": "binary"
            }
          },
          "additionalProperties": false,
          "required": [
            "test1",
            "test2"
          ]
        }
      },
      "request": {
        "method": "POST",
        "path": "/",
        "content_type": "multipart/form-data"
      },
      "expected_response": {
        "status_code": 200,
        "body": {
          "test1": {
            "filename": "test1.txt",
            "size": 15,
            "content": "<file1 content>",
            "content_type": "text/plain"
          },
          "test2": {
            "filename": "test2.txt",
            "size": 15,
            "content": "<file2 content>",
            "content_type": "text/plain"
          }
        }
      }
