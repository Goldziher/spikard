  {
    "id": "content_type_validation_invalid_type",
    "description": "Tests file upload with disallowed content type",
    "category": "multipart",
    "http": {
      "handler": {
        "route": "/files/images-only",
        "method": "POST",
        "body_schema": {
          "type": "object",
          "properties": {
            "file": {
              "type": "string",
              "format": "binary"
            }
          },
          "additionalProperties": false
        },
        "parameters": {
          "files": {
            "file": {
              "required": true,
              "content_type": [
                "image/jpeg",
                "image/png",
                "image/gif"
              ]
            }
          }
        }
      },
      "request": {
        "method": "POST",
        "path": "/files/images-only"
      },
      "expected_response": {
        "status_code": 422,
        "validation_errors": [
          {
            "type": "validation_error",
            "loc": [
              "files",
              "file"
            ],
            "msg": "Invalid content type 'application/x-sh'. Allowed types: image/jpeg, image/png, image/gif"
          }
        ]
      }
    }
  },
