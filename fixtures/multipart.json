  {
    "id": "file_upload_with_custom_headers",
    "description": "File upload with additional custom headers in the multipart section",
    "category": "multipart",
    "http": {
      "handler": {
        "route": "/",
        "method": "POST",
        "body_schema": {
          "type": "object",
          "properties": {
            "test2": {
              "type": "string",
              "format": "binary"
            }
          },
          "additionalProperties": false,
          "required": [
            "test2"
          ]
        }
      },
      "request": {
        "method": "POST",
        "path": "/",
        "content_type": "multipart/form-data"
      },
      "expected_response": {
        "status_code": 200,
        "body": {
          "test2": {
            "filename": "test2.txt",
            "size": 15,
            "content": "<file2 content>",
            "content_type": "text/plain",
            "headers": [
              [
                "content-disposition",
                "form-data; name=\"test2\"; filename=\"test2.txt\""
              ],
              [
                "content-type",
                "text/plain"
              ],
              [
                "x-custom",
                "f2"
              ]
            ]
          }
        }
      }
    }
  },
