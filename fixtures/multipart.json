  {
    "id": "multiple_values_for_same_field_name",
    "description": "Multiple files uploaded with the same field name (array-like behavior)",
    "category": "multipart",
    "http": {
      "handler": {
        "route": "/",
        "method": "POST",
        "body_schema": {
          "type": "object",
          "properties": {
            "files": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "binary"
              }
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "files"
          ]
        }
      },
      "request": {
        "method": "POST",
        "path": "/",
        "content_type": "multipart/form-data"
      },
      "expected_response": {
        "status_code": 200,
        "body": {
          "files": [
            {
              "filename": "file1.txt",
              "size": 10,
              "content": "first file",
              "content_type": "text/plain"
            },
            {
              "filename": "file2.txt",
              "size": 11,
              "content": "second file",
              "content_type": "text/plain"
            }
          ],
          "tags": [
            "python",
            "rust",
            "web"
          ]
        }
      }
    }
  },
