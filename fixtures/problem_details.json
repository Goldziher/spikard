[
	{
		"id": "problem_details_standard_all_fields",
		"description": "Tests RFC 9457 ProblemDetails response with all standard fields",
		"category": "problem_details",
		"http": {
			"handler": {
				"route": "/items/{id}",
				"method": "GET",
				"parameters": {
					"path": {
						"id": {
							"type": "string"
						}
					}
				}
			},
			"request": {
				"method": "GET",
				"path": "/items/999"
			},
			"expected_response": {
				"status_code": 404,
				"body": {
					"type": "https://spikard.dev/errors/not-found",
					"title": "Resource Not Found",
					"status": 404,
					"detail": "Item with ID 999 was not found",
					"instance": "/items/999"
				}
			}
		},
		"tags": ["problem_details", "rfc9457", "error"]
	},
	{
		"id": "problem_details_with_type_uri",
		"description": "Tests ProblemDetails includes type URI for error classification",
		"category": "problem_details",
		"http": {
			"handler": {
				"route": "/validate",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"value": {
							"type": "integer",
							"minimum": 1
						}
					},
					"required": ["value"]
				}
			},
			"request": {
				"method": "POST",
				"path": "/validate",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"value": -5
				}
			},
			"expected_response": {
				"status_code": 422,
				"body": {
					"type": "https://spikard.dev/errors/validation-error",
					"title": "Validation Failed",
					"status": 422,
					"detail": "Request validation failed"
				}
			}
		},
		"tags": ["problem_details", "rfc9457", "validation"]
	},
	{
		"id": "problem_details_with_instance",
		"description": "Tests ProblemDetails includes instance URI for context",
		"category": "problem_details",
		"http": {
			"handler": {
				"route": "/users/{user_id}/posts/{post_id}",
				"method": "GET",
				"parameters": {
					"path": {
						"user_id": {
							"type": "string"
						},
						"post_id": {
							"type": "string"
						}
					}
				}
			},
			"request": {
				"method": "GET",
				"path": "/users/123/posts/456"
			},
			"expected_response": {
				"status_code": 404,
				"body": {
					"type": "https://spikard.dev/errors/not-found",
					"title": "Post Not Found",
					"status": 404,
					"detail": "Post 456 not found for user 123",
					"instance": "/users/123/posts/456"
				}
			}
		},
		"tags": ["problem_details", "rfc9457", "instance"]
	},
	{
		"id": "problem_details_with_extensions",
		"description": "Tests ProblemDetails includes custom extensions for additional context",
		"category": "problem_details",
		"http": {
			"handler": {
				"route": "/api/resource",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"data": {
							"type": "string"
						}
					},
					"required": ["data"]
				}
			},
			"request": {
				"method": "POST",
				"path": "/api/resource",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": {
					"data": "invalid"
				}
			},
			"expected_response": {
				"status_code": 422,
				"body": {
					"type": "https://spikard.dev/errors/validation-error",
					"title": "Request Validation Failed",
					"status": 422,
					"detail": "Validation failed",
					"extensions": {
						"error_code": "VALIDATION_001",
						"timestamp": null,
						"trace_id": null
					}
				}
			}
		},
		"tags": ["problem_details", "rfc9457", "extensions"]
	},
	{
		"id": "problem_details_400_bad_request",
		"description": "Tests ProblemDetails for 400 Bad Request status",
		"category": "problem_details",
		"http": {
			"handler": {
				"route": "/parse",
				"method": "POST",
				"body_schema": {
					"type": "object",
					"properties": {
						"json": {
							"type": "object"
						}
					}
				}
			},
			"request": {
				"method": "POST",
				"path": "/parse",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": "invalid json"
			},
			"expected_response": {
				"status_code": 400,
				"body": {
					"type": "https://spikard.dev/errors/bad-request",
					"title": "Bad Request",
					"status": 400,
					"detail": "Invalid JSON in request body"
				}
			}
		},
		"tags": ["problem_details", "rfc9457", "400"]
	},
	{
		"id": "problem_details_401_unauthorized",
		"description": "Tests ProblemDetails for 401 Unauthorized status",
		"category": "problem_details",
		"http": {
			"handler": {
				"route": "/protected",
				"method": "GET",
				"middleware": {
					"jwt_auth": {
						"enabled": true,
						"algorithm": "HS256",
						"secret": "test-secret"
					}
				}
			},
			"request": {
				"method": "GET",
				"path": "/protected"
			},
			"expected_response": {
				"status_code": 401,
				"body": {
					"type": "https://spikard.dev/errors/unauthorized",
					"title": "Unauthorized",
					"status": 401,
					"detail": "Authentication required"
				}
			}
		},
		"tags": ["problem_details", "rfc9457", "401"]
	},
	{
		"id": "problem_details_403_forbidden",
		"description": "Tests ProblemDetails for 403 Forbidden status",
		"category": "problem_details",
		"http": {
			"handler": {
				"route": "/admin/config",
				"method": "GET",
				"middleware": {
					"authorization": {
						"required_role": "admin"
					}
				}
			},
			"request": {
				"method": "GET",
				"path": "/admin/config"
			},
			"expected_response": {
				"status_code": 403,
				"body": {
					"type": "https://spikard.dev/errors/forbidden",
					"title": "Forbidden",
					"status": 403,
					"detail": "Insufficient permissions to access this resource"
				}
			}
		},
		"tags": ["problem_details", "rfc9457", "403"]
	},
	{
