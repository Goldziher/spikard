		"category": "di",
		"http": {
			"handler": {
				"route": "/api/request-id",
				"method": "GET"
			},
			"request": {
				"method": "GET",
				"path": "/api/request-id"
			},
			"expected_response": {
				"status_code": 200,
				"body": {
					"first_id": "<<uuid>>",
					"second_id": "<<same_as:first_id>>"
				}
			}
		},
		"tags": ["dependency_injection", "per-request", "caching"]
	},
	{
		"id": "circular_dependency_detection_error",
		"description": "Tests that circular dependencies (A depends on B, B depends on A) are detected and rejected at registration time",
		"category": "di",
		"http": {
			"handler": {
				"route": "/api/circular",
				"method": "GET"
			},
			"request": {
				"method": "GET",
				"path": "/api/circular"
			},
			"expected_response": {
				"status_code": 500,
				"body": {
					"type": "https://spikard.dev/errors/dependency-error",
					"title": "Dependency Resolution Failed",
					"status": 500,
					"detail": "Circular dependency detected",
					"errors": [
						{
							"type": "circular_dependency",
							"msg": "Circular dependency detected in dependency graph",
							"cycle": ["service_a", "service_b", "service_a"]
						}
					]
				}
			}
		},
		"tags": ["dependency_injection", "error", "circular", "validation"]
	},
	{
		"id": "missing_dependency_error",
		"description": "Tests error when handler requires a dependency that was never registered",
		"category": "di",
		"http": {
			"handler": {
				"route": "/api/missing-dep",
				"method": "GET"
			},
			"request": {
				"method": "GET",
				"path": "/api/missing-dep"
			},
			"expected_response": {
				"status_code": 500,
				"body": {
					"type": "https://spikard.dev/errors/dependency-error",
					"title": "Dependency Resolution Failed",
					"status": 500,
					"detail": "Required dependency not found",
					"errors": [
						{
							"type": "missing_dependency",
							"msg": "Dependency 'non_existent_service' is not registered",
							"dependency_key": "non_existent_service"
						}
					]
				}
			}
		},
		"tags": ["dependency_injection", "error", "missing"]
	},
	{
		"id": "type_mismatch_in_dependency_resolution_error",
		"description": "Tests error when handler expects a different type than what the dependency provides",
		"category": "di",
		"http": {
			"handler": {
				"route": "/api/type-mismatch",
				"method": "GET"
			},
			"request": {
				"method": "GET",
				"path": "/api/type-mismatch"
			},
			"expected_response": {
				"status_code": 500,
				"body": {
					"type": "https://spikard.dev/errors/dependency-error",
					"title": "Dependency Resolution Failed",
					"status": 500,
					"detail": "Dependency type mismatch",
					"errors": [
						{
							"type": "type_mismatch",
							"msg": "Dependency 'config' type mismatch: expected object, got string",
							"dependency_key": "config",
							"expected_type": "object",
							"actual_type": "string"
						}
					]
				}
			}
		},
		"tags": ["dependency_injection", "error", "type_mismatch"]
	},
