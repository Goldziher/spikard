{
  "name": "@spikard/node",
  "version": "0.15.6-rc.12",
  "description": "Rust-centric multi-language HTTP framework with polyglot bindings",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Goldziher/spikard.git"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npx --yes -p @napi-rs/cli@^3.6.2 napi build --platform --release",
    "artifacts": "npx --yes -p @napi-rs/cli@^3.6.2 napi artifacts",
    "prepublishOnly": "npx --yes -p @napi-rs/cli@^3.6.2 napi prepublish -t npm --skip-optional-publish"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2"
  },
  "optionalDependencies": {
    "@spikard/node-darwin-arm64": "0.15.6-rc.12",
    "@spikard/node-darwin-x64": "0.15.6-rc.12",
    "@spikard/node-linux-arm64-gnu": "0.15.6-rc.12",
    "@spikard/node-linux-arm64-musl": "0.15.6-rc.12",
    "@spikard/node-linux-x64-gnu": "0.15.6-rc.12",
    "@spikard/node-linux-x64-musl": "0.15.6-rc.12",
    "@spikard/node-win32-arm64-msvc": "0.15.6-rc.12",
    "@spikard/node-win32-x64-msvc": "0.15.6-rc.12"
  },
  "napi": {
    "binaryName": "spikard-node",
    "packageName": "@spikard/node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">= 18"
  }
}
