{
  "name": "@spikard/node",
  "version": "0.17.0-rc.4",
  "description": "Rust-centric multi-language HTTP framework with polyglot bindings",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Goldziher/spikard.git"
  },
  "main": "index-wrapper.cjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index-wrapper.cjs",
      "default": "./index-wrapper.cjs"
    },
    "./service": {
      "types": "./index.d.ts",
      "require": "./service.cjs",
      "default": "./service.cjs"
    }
  },
  "files": ["app.cjs", "app.d.ts", "index.js", "index-wrapper.cjs", "index.d.ts", "service.cjs", "*.node"],
  "dependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "optionalDependencies": {
    "@spikard/node-linux-x64-gnu": "0.17.0-rc.4",
    "@spikard/node-linux-arm64-gnu": "0.17.0-rc.4",
    "@spikard/node-linux-x64-musl": "0.17.0-rc.4",
    "@spikard/node-linux-arm64-musl": "0.17.0-rc.4",
    "@spikard/node-darwin-arm64": "0.17.0-rc.4",
    "@spikard/node-win32-x64-msvc": "0.17.0-rc.4",
    "@spikard/node-win32-arm64-msvc": "0.17.0-rc.4"
  },
  "napi": {
    "packageName": "@spikard/node",
    "binaryName": "spikard-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "npx --yes -p @napi-rs/cli@^3.7.3 napi build --platform --release",
    "artifacts": "npx --yes -p @napi-rs/cli@^3.7.3 napi artifacts",
    "prepublishOnly": "npx --yes -p @napi-rs/cli@^3.7.3 napi prepublish -t npm --skip-optional-publish"
  },
  "engines": { "node": ">= 22" },
  "publishConfig": { "access": "public" },
  "devDependencies": { "@napi-rs/cli": "^3.7.3" }
}
