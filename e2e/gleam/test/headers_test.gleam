  let assert Ok(req) = request.to(base_url <> "/fixtures/x_api_key_required_header_success")
  let req = request.set_method(req, http.Get)
  let req = request.set_header(req, "key", "secret")
  let assert Ok(resp) = httpc.send(req)
  resp.status |> should.equal(200)
  resp.body |> string.trim |> should.equal("{\"username\":\"secret\"}")
}
